{
    "name": "carloschininin/facturax-sunat",
    "description": "Catálogos SUNAT del Anexo N.° 8 para interpretar códigos de comprobantes electrónicos, resúmenes y documentos relacionados.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "CarlosChininin\\FacturaxSunat\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload-dev": {
        "psr-4": {
            "CarlosChininin\\FacturaxSunat\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
